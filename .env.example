# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=dolma
DATABASE_PASSWORD=dolma_password
DATABASE_NAME=dolma_ai
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=dolma-ai-storage

# Claude AI
CLAUDE_API_KEY=your-claude-api-key

# WhatsApp
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# Instagram
INSTAGRAM_VERIFY_TOKEN=your-instagram-verify-token
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# TikTok
TIKTOK_VERIFY_TOKEN=your-tiktok-verify-token
TIKTOK_APP_SECRET=your-tiktok-app-secret

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
